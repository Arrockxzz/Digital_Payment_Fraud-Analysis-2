      <aliases enabled='yes' />
      <column caption='Fraud Transactions' datatype='integer' name='[Calculation_1721076872122369]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([fraud_label])' />
      </column>
      <column caption='Fraud %' datatype='real' name='[Calculation_1721076872220674]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([fraud_label]) / COUNT([transaction_id])' />
      </column>
      <column caption='High Risk IP' datatype='string' name='[Calculation_1721076872306691]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [ip_risk_score] &gt; 0.8&#13;&#10;THEN &quot;High Risk&quot;&#13;&#10;ELSE &quot;Normal&quot;&#13;&#10;END' />
      </column>
      <column caption='Suspicious Login' datatype='string' name='[Calculation_1721076872392708]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [login_attempts_last_24h] &gt; 5&#13;&#10;OR [previous_failed_attempts] &gt; 2&#13;&#10;THEN &quot;Suspicious&quot;&#13;&#10;ELSE &quot;Normal&quot;&#13;&#10;END' />
      </column>
      <column caption='Transaction Time Bucket' datatype='string' name='[Calculation_1721076872478725]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [transaction_hour] &lt;= 5 THEN &quot;Late Night&quot;&#13;&#10;ELSEIF [transaction_hour] &lt;= 11 THEN &quot;Morning&quot;&#13;&#10;ELSEIF [transaction_hour] &lt;=17 THEN &quot;Afternoon&quot;&#13;&#10;ELSE &quot;Evening&quot;&#13;&#10;END' />
      </column>
      <column caption='International %' datatype='real' name='[Calculation_1721076872568838]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([is_international])' />
      </column>
      <column caption='Max Fraud Amount' datatype='real' name='[Calculation_1721076881817607]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MAX(&#13;&#10;IF [fraud_label] = 1&#13;&#10;THEN [transaction_amount]&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='Risk Score' datatype='real' name='[Calculation_1721076882419720]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(&#13;&#10;&#13;&#10;(&#13;&#10;[ip_risk_score] * 40&#13;&#10;&#13;&#10;+&#13;&#10;&#13;&#10;(MIN([previous_failed_attempts],5)/5)*20&#13;&#10;&#13;&#10;+&#13;&#10;&#13;&#10;(MIN([login_attempts_last_24h],10)/10)*20&#13;&#10;&#13;&#10;+&#13;&#10;&#13;&#10;([is_international] * 10)&#13;&#10;&#13;&#10;+&#13;&#10;&#13;&#10;(&#13;&#10;IF [account_age_days] &lt; 90&#13;&#10;THEN 10&#13;&#10;ELSE 0&#13;&#10;END&#13;&#10;)&#13;&#10;&#13;&#10;)&#13;&#10;&#13;&#10;)' />
      </column>
      <column caption='Total Fraud Amount' datatype='real' name='[Calculation_1721076961333259]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;IF [fraud_label] = 1&#13;&#10;THEN [transaction_amount]&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='Digital_Payment_Fraud_Detection' datatype='table' name='[__tableau_internal_object_id__].[Digital!Payment!Fraud!Detection_7AF594245F5B465ABE45DA545C2B6BA0]' role='measure' type='quantitative' />
      <column caption='Account Age Days' datatype='integer' name='[account_age_days]' role='measure' type='quantitative' />
